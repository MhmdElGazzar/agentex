# AgenTeX — environment configuration (example)
#
# Copy to `.env` and fill in the values:  cp .env.example .env
# `.env` is gitignored — never commit real secrets.


# ─── Target under test ────────────────────────────────────────────────────────
QA_TARGET_URL=https://example.com


# ─── Azure DevOps ─────────────────────────────────────────────────────────────
# Used by the task-estimation skill (az boards / az devops).
AZURE_URL=https://dev.azure.com/your-org
AZURE_PROJECT=your-project
AZURE_TEAM=your-team
AZURE_ASSIGNEE=qa.engineer@example.com
# PAT for non-interactive auth. The azure-devops extension reads it from the env var
# AZURE_DEVOPS_EXT_PAT — export it in your shell (the agent never prints or passes the PAT):
#   export AZURE_DEVOPS_EXT_PAT="$AZURE_PAT"
AZURE_PAT=
